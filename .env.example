# Database (used by both the app and Alembic migrations)
DATABASE_URL=postgresql+psycopg://infermail:changeme@db/infermail

# PostgreSQL container credentials (must match DATABASE_URL above)
POSTGRES_USER=infermail
POSTGRES_PASSWORD=changeme
POSTGRES_DB=infermail

# IMAP account passwords
ACCOUNT_GMAIL_PASSWORD=
ACCOUNT_STRATO_PASSWORD=
ACCOUNT_GMX_PASSWORD=

# Paths (Docker defaults — override for local dev)
BACKUP_DIR=/app/backups
